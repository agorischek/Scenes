{
  "name": "Clock Playground Demo",
  "steps": [
    {
      "type": "runShellCommand",
      "command": "pkill -x ghostty || true"
    },
    {
      "type": "delay",
      "seconds": 1.0
    },
    {
      "type": "launchApp",
      "bundleIdentifier": "com.mitchellh.ghostty"
    },
    {
      "type": "delay",
      "seconds": 1.5
    },
    {
      "type": "moveWindow",
      "bundleIdentifier": "com.mitchellh.ghostty",
      "xFraction": 0.0,
      "yFraction": 0.0,
      "widthFraction": 0.5,
      "heightFraction": 1.0
    },
    {
      "type": "delay",
      "seconds": 0.5
    },
    {
      "type": "typeText",
      "text": "cd /Users/umeboshi/Git/clock-playground && npm run workstream"
    },
    {
      "type": "pressKey",
      "key": "return"
    },
    {
      "type": "runShellCommand",
      "command": "cd /Users/umeboshi/Git/clock-playground && npm run observe"
    },
    {
      "type": "delay",
      "seconds": 2.0
    },
    {
      "type": "moveFrontmostWindow",
      "xFraction": 0.5,
      "yFraction": 0.0,
      "widthFraction": 0.5,
      "heightFraction": 1.0
    }
  ]
}
