{
  "name": "Clock Playground Demo",
  "steps": [
    {
      "type": "runShellCommand",
      "command": "pkill -x Terminal || true"
    },
    {
      "type": "delay",
      "seconds": 1.0
    },
    {
      "type": "launchApp",
      "bundleIdentifier": "com.apple.Terminal"
    },
    {
      "type": "delay",
      "seconds": 1.5
    },
    {
      "type": "moveWindow",
      "bundleIdentifier": "com.apple.Terminal",
      "xFraction": 0.0,
      "yFraction": 0.0,
      "widthFraction": 0.5,
      "heightFraction": 1.0
    },
    {
      "type": "delay",
      "seconds": 0.5
    },
    {
      "type": "runShellCommand",
      "command": "osascript -e 'tell application \"Terminal\" to do script \"cd /Users/umeboshi/Git/clock-playground && npm run workstream\"' -e 'tell application \"Terminal\" to activate'"
    },
    {
      "type": "runShellCommand",
      "command": "cd /Users/umeboshi/Git/clock-playground && npm run observe"
    },
    {
      "type": "delay",
      "seconds": 2.0
    },
    {
      "type": "moveFrontmostWindow",
      "xFraction": 0.5,
      "yFraction": 0.0,
      "widthFraction": 0.5,
      "heightFraction": 1.0
    }
  ]
}
